# PostgreSQL connection string
# Local:  postgresql://USER:PASSWORD@localhost:5432/compliance_tracker
# Hosted: copy the pooled connection string from your database provider
DATABASE_URL="postgresql://user:password@localhost:5432/compliance_tracker"

# Auth.js secret — generate with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-generated-secret"

# Base URL of the app (set to the deployed URL in production)
AUTH_URL="http://localhost:3000"
